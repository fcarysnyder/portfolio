---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GatedContent from '../../components/work/GatedContent.tsx';

export async function getStaticPaths() {
  const all = await getCollection('work');
  return all
    .filter((entry) => entry.data.gated === true)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = entry.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const lockedDataUrl = `/data/${entry.id}.locked.json`;
---

<BaseLayout
  title={`${entry.data.title} | F Cary Snyder`}
  description={entry.data.description}
  image={entry.data.img}
>
  <main class="wrapper post-layout">
    <article>
      <header class="post-header">
        <a href="/" class="back-link">&larr; Back</a>
        <h1>{entry.data.title}</h1>
        <time datetime={entry.data.publishDate.toISOString()}>{formattedDate}</time>
      </header>

      {entry.data.img && (
        <img class="hero-image" src={entry.data.img} alt={entry.data.img_alt ?? ''} />
      )}

      <div class="post-content">
        {/* Public teaser from the MDX stub body */}
        <div class="teaser"><Content /></div>

        {entry.data.gated ? (
          <GatedContent lockedDataUrl={lockedDataUrl} client:load />
        ) : null}
      </div>

      <footer class="post-footer">
        <div class="post-meta">
          <div class="meta-row">
            <span class="meta-label">Date</span>
            <span class="meta-value">{formattedDate}</span>
          </div>
          {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="meta-row">
              <span class="meta-label">Tags</span>
              <span class="meta-value">{entry.data.tags.join(', ')}</span>
            </div>
          )}
        </div>
      </footer>
    </article>
  </main>
</BaseLayout>

<style>
  .post-layout {
    display: flex;
    flex-direction: column;
  }
  article {
    width: 100%;
  }
  .post-header {
    position: relative;
    padding-top: 2rem;
  }
  .back-link {
    position: absolute;
    top: 0;
    left: 0;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--accent-regular);
    text-decoration: none;
  }
  .back-link:hover {
    color: var(--accent-dark);
  }
  .post-header h1 {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    color: var(--gray-0);
    margin-bottom: 0.5rem;
  }
  .post-header time {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-sm);
    color: var(--gray-400);
  }
  .hero-image {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: var(--shadow-md);
    margin-top: 2rem;
  }
  .post-content {
    margin-top: 2.5rem;
  }
  .teaser {
    color: var(--gray-200);
    font-size: var(--font-size-base);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .post-content :global(.gated-placeholder) {
    padding: 2rem;
    background: var(--gradient-subtle);
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    color: var(--gray-300);
    text-align: center;
  }
  /* Decrypted HTML rendering */
  .post-content :global(.gated-content h2) {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    color: var(--gray-0);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .post-content :global(.gated-content h3) {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--gray-0);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post-content :global(.gated-content p) {
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: var(--gray-200);
  }
  .post-content :global(.gated-content p + p) {
    margin-top: 1.5em;
  }
  .post-content :global(.gated-content a) {
    color: var(--accent-regular);
  }
  .post-content :global(.gated-content blockquote) {
    border-left: 3px solid var(--accent-regular);
    padding-left: 1rem;
    color: var(--gray-200);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .post-content :global(.gated-content img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: var(--shadow-md);
    margin: 2rem auto;
  }
  .post-content :global(.gated-content ul),
  .post-content :global(.gated-content ol) {
    color: var(--gray-200);
    font-size: var(--font-size-base);
    line-height: 1.7;
    padding-left: 1.5em;
    margin-top: 1em;
  }
  .post-content :global(.gated-content li + li) {
    margin-top: 0.5em;
  }
  .post-footer {
    margin-top: 3rem;
  }
  .post-meta {
    border-top: 1px solid var(--gray-800);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .meta-row {
    display: flex;
    gap: 1rem;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-sm);
  }
  .meta-label {
    color: var(--gray-400);
    text-transform: uppercase;
    min-width: 4rem;
  }
  .meta-value {
    color: var(--gray-200);
  }
  @media (min-width: 60em) {
    .post-layout {
      display: grid;
      grid-template-columns: 1fr 60% 1fr;
    }
    article {
      grid-column: 2;
    }
    .post-header h1 {
      font-size: var(--font-size-3xl);
    }
  }
</style>
