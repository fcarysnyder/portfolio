---
import type { CollectionEntry } from 'astro:content';
import Pill from '../components/Pill.astro';
import { ArrowRight, Lock } from '@lucide/astro';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
const firstTag = data.tags && data.tags.length > 0 ? data.tags[0] : '';
const href = data.gated ? `/work/${id}/` : (data.url ?? `/work/${id}/`);
const cta = data.cta ?? (data.gated ? 'ask for access' : 'view project');
const pillTextColor = firstTag === 'CrossnoKaye' ? '#000' : undefined;
---

<div>
	<a class="card" href={href}>
		<div class="img-wrap">
			<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
		</div>
		<div class="card-descrip">
			<div class="card-tags">
				{firstTag && (
					<span style={pillTextColor ? `--accent-text-over: ${pillTextColor}` : ''}>
						<Pill color={data.color}>{firstTag}</Pill>
					</span>
				)}
				{data.gated && (
					<span class="lock-pill" aria-label="Password protected">
						<Lock size="0.85em" />
						<span>Gated</span>
					</span>
				)}
			</div>
			<h3 class="title">{data.title}</h3>
			<p class="description">{data.description}</p>
			<span class="faux-button">{cta} <ArrowRight size="1em" /></span>
		</div>
	</a>
</div>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-family-brand);
		font-size: var(--font-size-lg);
		font-weight: 400;
		transition: box-shadow var(--theme-transition);
		width: 100%;
	}
	.card:hover {
		box-shadow: var(--shadow-md);
	}
	.description {
		color: var(--gray-300);
		font-size: 16px;
	}
	.faux-button {
		grid-column-gap: 4px;
		grid-row-gap: 4px;
		align-items: center;
		display: flex;
		font-size: var(--font-size-xs);
		padding-top: 24px;
		text-transform: uppercase;
		color: var(--accent-regular);
	}
	.faux-button:hover {
		color: var(--accent-dark);
	}
	.card-descrip {
		grid-column-gap: 0px;
		object-fit: fill;
		border-radius: 0 0 8px 8px;
		flex-direction: column;
		flex: 1;
		align-items: flex-start;
		margin-right: 0;
		padding: 40px;
		display: flex;
	}
	.card-tags {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.lock-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.15rem 0.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 999px;
		font-size: var(--font-size-xs);
		color: var(--gray-300);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.title {
		z-index: 1;
		color: var(--gray-200);
		border-radius: 0.375rem;
		font-size: 24px !important;
		padding-top: 12px;
		padding-bottom: 24px;
	}
	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	@media (min-width: 70em) {
		.card {
			display: flex;
			flex-direction: row;
			border-radius: 1.5rem;
			overflow: hidden;
		}
		.card-descrip {
			flex: 3;
			border-radius: 0;
		}
		.img-wrap {
			flex: 2;
			position: relative;
			min-width: 0;
		}
		img {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
		.title {
			border-radius: 0.9375rem;
		}
	}
</style>
