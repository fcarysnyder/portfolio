---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { BookOpen } from '@lucide/astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const sortedByDate = [...posts].sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const sortedByTitle = [...posts].sort(
	(a, b) => a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout title="Writing | F Cary Snyder" description="Writing by F Cary Snyder">
	<main class="wrapper writing">
		<h1>Writing</h1>
		<SectionHeader label="All Posts">
			<BookOpen slot="icon" size={18} />
			<Fragment slot="filters">
				<a href="?sort=date" class="filter-option" data-sort="date">Date</a>
				<span class="filter-dot" aria-hidden="true">&middot;</span>
				<a href="?sort=title" class="filter-option" data-sort="title">Title (A-Z)</a>
			</Fragment>
		</SectionHeader>
		<ul class="post-list" data-list>
			{sortedByDate.map((post) => (
				<li data-title={post.data.title} data-date={post.data.publishDate.valueOf()}>
					<a href={`/writing/${post.id}/`}>{post.data.title}</a>
					<time datetime={post.data.publishDate.toISOString()}>
						{post.data.publishDate.toLocaleDateString('en-US', {
							month: 'long',
							day: 'numeric',
							year: 'numeric',
						})}
					</time>
				</li>
			))}
		</ul>
	</main>
</BaseLayout>

<script>
	function applySort(sort: string) {
		// Highlight active sort option
		document.querySelectorAll('.filter-option').forEach((el) => {
			if (el instanceof HTMLAnchorElement) {
				el.classList.toggle('active', el.dataset.sort === sort);
			}
		});

		// Sort the list
		const list = document.querySelector('[data-list]');
		if (!list) return;

		const items = [...list.querySelectorAll('li')];
		items.sort((a, b) => {
			if (sort === 'title') {
				return (a.dataset.title || '').localeCompare(b.dataset.title || '');
			}
			return Number(b.dataset.date) - Number(a.dataset.date);
		});

		items.forEach((item) => list.appendChild(item));
	}

	function initSort() {
		const params = new URLSearchParams(window.location.search);
		applySort(params.get('sort') || 'date');

		document.querySelectorAll('.filter-option').forEach((el) => {
			el.addEventListener('click', (e) => {
				e.preventDefault();
				const sort = (el as HTMLAnchorElement).dataset.sort || 'date';
				history.replaceState(null, '', `?sort=${sort}`);
				applySort(sort);
			});
		});
	}

	initSort();
	document.addEventListener('astro:after-swap', initSort);
</script>

<style>
	.writing {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	h1 {
		font-size: var(--font-size-2xl);
		color: var(--gray-0);
	}

	@media (min-width: 60em) {
		h1 {
			font-size: var(--font-size-3xl);
		}
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-list li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}

	.post-list a {
		color: var(--gray-0);
		text-decoration: none;
		font-size: var(--font-size-lg);
		font-weight: 400;
	}

	.post-list a:hover,
	.post-list a:focus {
		color: var(--accent-regular);
	}

	.post-list time {
		font-family: var(--font-family-mono);
		font-size: var(--font-size-sm);
		color: var(--gray-400);
		white-space: nowrap;
	}
</style>
