---
interface Props {
	title: string;
	tagline?: string;
}

const { tagline, title } = Astro.props;
---

<div class="about-hero">
	<div class="wrapper stack gap-2">
		<h1 class="title">{title}</h1>
		{tagline && <p class="tagline">{tagline}</p>}
	</div>
	<div class="carousel-container">
		<div class="carousel-track">
			<slot />
			<slot />
		</div>
	</div>
</div>

<style>
	.about-hero {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-bottom: 3rem;
	}

	.title {
		max-width: 37ch;
		font-size: var(--font-size-2xl);
		color: var(--gray-0);
	}

	.tagline {
		font-size: 1.5rem; /* 24px */
		line-height: 2rem; /* 32px */
		max-width: 60ch;
	}

	.carousel-container {
		overflow: hidden;
		mask-image: linear-gradient(
			to right, 
			rgba(0,0,0,0.2) 0%,
			black 15%,
			black 90%,
			rgba(0,0,0,0.2) 100%
		);
		-webkit-mask-image: linear-gradient(
			to right, 
			rgba(0,0,0,0.2) 0%,
			black 15%,
			black 90%,
			rgba(0,0,0,0.2) 100%
		);
        padding-bottom: 2rem;
	}

	.carousel-track {
		--gap: 2em;
		display: flex;
		gap: var(--gap);
		width: max-content;
		will-change: transform;
	}

	.carousel-track :global(img) {
		width: 600px;
		height: 500px;
		object-fit: cover;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 60em) {
		.title {
			font-size: var(--font-size-3xl);
		}
	}

	@media (max-width: 59.99em) {
		.carousel-track :global(img) {
			width: 300px;
			height: 250px;
		}
	}
</style>

<script>
	const containers = document.querySelectorAll('.carousel-container');

	containers.forEach((container) => {
		const track = container.querySelector('.carousel-track') as HTMLElement;
		if (!track) return;

		const gap = parseFloat(getComputedStyle(track).gap) || 0;
		const totalDistance = track.scrollWidth / 2 + gap / 2;
		const baseSpeed = totalDistance / 40000;

		let currentSpeed = baseSpeed;
		let targetSpeed = baseSpeed;
		let position = 0;
		let lastTime = performance.now();
		let transitionStartTime: number | null = null;
		let transitionStartSpeed = baseSpeed;
		const TRANSITION_MS = 400;

		function easeInOutCubic(t: number) {
			return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
		}

		function animate(now: number) {
			const dt = now - lastTime;
			lastTime = now;

			if (transitionStartTime !== null) {
				const progress = Math.min((now - transitionStartTime) / TRANSITION_MS, 1);
				currentSpeed =
					transitionStartSpeed +
					(targetSpeed - transitionStartSpeed) * easeInOutCubic(progress);
				if (progress >= 1) {
					transitionStartTime = null;
					currentSpeed = targetSpeed;
				}
			}

			position = (position + currentSpeed * dt) % totalDistance;
			track.style.transform = `translateX(${-position}px)`;

			requestAnimationFrame(animate);
		}

		function setTargetSpeed(speed: number) {
			transitionStartTime = performance.now();
			transitionStartSpeed = currentSpeed;
			targetSpeed = speed;
		}

		container.addEventListener('mouseenter', () => setTargetSpeed(0));
		container.addEventListener('mouseleave', () => setTargetSpeed(baseSpeed));

		requestAnimationFrame(animate);
	});
</script>